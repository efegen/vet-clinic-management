@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    string NavActive(string c) => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Vet Klinik</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VetClinic.Web.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark app-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-semibold d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-clipboard2-pulse fs-4"></i>
                    <span>Vet Klinik</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Menüyü aç/kapat">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link @NavActive("Home")" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i>Anasayfa
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @NavActive("Owners")" asp-controller="Owners" asp-action="Index">
                                <i class="bi bi-person-lines-fill me-1"></i>Sahipler
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @NavActive("Pets")" asp-controller="Pets" asp-action="Index">
                                <i class="bi bi-heart-pulse me-1"></i>Hayvanlar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @NavActive("Services")" asp-controller="Services" asp-action="Index">
                                <i class="bi bi-clipboard2-check me-1"></i>Hizmetler
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @NavActive("Appointments")" asp-controller="Appointments" asp-action="Index">
                                <i class="bi bi-calendar2-week me-1"></i>Randevular
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="container my-4 flex-grow-1">
        @{
            var flashMap = new (string Key, string Css, string Icon)[]
            {
                ("Success", "alert-success",  "bi-check-circle-fill"),
                ("Error",   "alert-danger",   "bi-exclamation-octagon-fill"),
                ("Warning", "alert-warning",  "bi-exclamation-triangle-fill"),
                ("Info",    "alert-info",     "bi-info-circle-fill"),
            };
        }
        @foreach (var (key, css, icon) in flashMap)
        {
            if (TempData[key] is string msg && !string.IsNullOrWhiteSpace(msg))
            {
                <div class="alert @css alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
                    <i class="bi @icon"></i>
                    <div>@msg</div>
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Kapat"></button>
                </div>
            }
        }

        @RenderBody()
    </main>

    <footer class="app-footer mt-auto py-3">
        <div class="container d-flex flex-wrap justify-content-between align-items-center small text-muted">
            <span>&copy; @DateTime.Now.Year Vet Klinik — Randevu Yönetim Sistemi</span>
            <span class="text-uppercase">Sürüm 1.0</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
