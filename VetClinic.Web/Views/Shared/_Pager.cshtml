@model PagerModel
@{
    if (Model.TotalPages <= 1) { return; }

    // Gösterilecek sayfa penceresi (aktif sayfanın çevresi).
    int window = 2;
    int start = Math.Max(1, Model.Page - window);
    int end = Math.Min(Model.TotalPages, Model.Page + window);
}
<nav aria-label="Sayfalama" class="d-flex justify-content-center mt-3">
    <ul class="pagination mb-0">
        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
            <a class="page-link" asp-action="@Model.Action" asp-all-route-data="@Model.RouteFor(Model.Page - 1)" aria-label="Önceki">
                <i class="bi bi-chevron-left"></i>
            </a>
        </li>

        @if (start > 1)
        {
            <li class="page-item"><a class="page-link" asp-action="@Model.Action" asp-all-route-data="@Model.RouteFor(1)">1</a></li>
            if (start > 2)
            {
                <li class="page-item disabled"><span class="page-link">…</span></li>
            }
        }

        @for (int p = start; p <= end; p++)
        {
            <li class="page-item @(p == Model.Page ? "active" : "")">
                <a class="page-link" asp-action="@Model.Action" asp-all-route-data="@Model.RouteFor(p)">@p</a>
            </li>
        }

        @if (end < Model.TotalPages)
        {
            if (end < Model.TotalPages - 1)
            {
                <li class="page-item disabled"><span class="page-link">…</span></li>
            }
            <li class="page-item"><a class="page-link" asp-action="@Model.Action" asp-all-route-data="@Model.RouteFor(Model.TotalPages)">@Model.TotalPages</a></li>
        }

        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
            <a class="page-link" asp-action="@Model.Action" asp-all-route-data="@Model.RouteFor(Model.Page + 1)" aria-label="Sonraki">
                <i class="bi bi-chevron-right"></i>
            </a>
        </li>
    </ul>
</nav>
