@{
    var current = ViewContext.RouteData.Values["action"]?.ToString();
    bool isCalendar = string.Equals(current, "Index", StringComparison.OrdinalIgnoreCase);
}
<div class="btn-group" role="group" aria-label="Görünüm">
    <a class="btn btn-sm @(isCalendar ? "btn-primary" : "btn-outline-secondary")" asp-action="Index">
        <i class="bi bi-calendar3 me-1"></i>Takvim
    </a>
    <a class="btn btn-sm @(!isCalendar ? "btn-primary" : "btn-outline-secondary")" asp-action="List">
        <i class="bi bi-list-ul me-1"></i>Liste
    </a>
</div>
