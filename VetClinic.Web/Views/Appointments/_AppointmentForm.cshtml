@model AppointmentCreateEditViewModel

<input type="hidden" asp-for="Id" />

<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="PetId" class="form-label">Hayvan <span class="required-mark">*</span></label>
        <select asp-for="PetId" asp-items="Model.PetOptions" class="form-select">
            <option value="">— Hayvan seçin —</option>
        </select>
        <span asp-validation-for="PetId" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="ServiceId" class="form-label">Hizmet <span class="required-mark">*</span></label>
        <select asp-for="ServiceId" asp-items="Model.ServiceOptions" class="form-select">
            <option value="">— Hizmet seçin —</option>
        </select>
        <span asp-validation-for="ServiceId" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="AppointmentDate" class="form-label">Randevu Tarihi / Saati <span class="required-mark">*</span></label>
        <input asp-for="AppointmentDate" asp-format="{0:yyyy-MM-ddTHH:mm}" type="datetime-local" class="form-control" />
        <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
        <div class="form-text">Mesai saatleri 09:00–19:00. Pazar günleri randevu alınamaz.</div>
    </div>

    @if (Model.Id.HasValue)
    {
        <div class="col-md-6">
            <label asp-for="Status" class="form-label">Durum</label>
            <select asp-for="Status" class="form-select">
                @foreach (var st in Enum.GetValues<AppointmentStatus>())
                {
                    <option value="@st">@st.ToText()</option>
                }
            </select>
            <span asp-validation-for="Status" class="text-danger small"></span>
        </div>
    }

    <div class="col-12">
        <label asp-for="Notes" class="form-label">Notlar</label>
        <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Hekim notu veya ek bilgi (opsiyonel)"></textarea>
        <span asp-validation-for="Notes" class="text-danger small"></span>
    </div>
</div>
