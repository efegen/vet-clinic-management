@model PetCreateEditViewModel

<input type="hidden" asp-for="Id" />

<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Name" class="form-label">Hayvan Adı <span class="required-mark">*</span></label>
        <input asp-for="Name" class="form-control" placeholder="Örn. Pamuk" autocomplete="off" />
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="OwnerId" class="form-label">Sahibi <span class="required-mark">*</span></label>
        <select asp-for="OwnerId" asp-items="Model.OwnerOptions" class="form-select">
            <option value="">— Sahip seçin —</option>
        </select>
        <span asp-validation-for="OwnerId" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Species" class="form-label">Tür <span class="required-mark">*</span></label>
        <select asp-for="Species" class="form-select">
            @foreach (var s in Enum.GetValues<PetSpecies>())
            {
                <option value="@s">@s.ToText()</option>
            }
        </select>
        <span asp-validation-for="Species" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Breed" class="form-label">Cins</label>
        <input asp-for="Breed" class="form-control" placeholder="Örn. Golden Retriever" autocomplete="off" />
        <span asp-validation-for="Breed" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="BirthDate" class="form-label">Doğum Tarihi <span class="required-mark">*</span></label>
        <input asp-for="BirthDate" type="date" class="form-control" />
        <span asp-validation-for="BirthDate" class="text-danger small"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Weight" class="form-label">Kilo (kg)</label>
        <input asp-for="Weight" type="number" step="0.1" min="0.1" class="form-control" placeholder="Örn. 4.2" />
        <span asp-validation-for="Weight" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label class="form-label d-block">Cinsiyet <span class="required-mark">*</span></label>
        <div class="d-flex gap-3">
            @foreach (var g in Enum.GetValues<PetGender>())
            {
                <div class="form-check">
                    <input class="form-check-input" type="radio" asp-for="Gender" value="@g" id="gender-@g" />
                    <label class="form-check-label" for="gender-@g">@g.ToText()</label>
                </div>
            }
        </div>
        <span asp-validation-for="Gender" class="text-danger small"></span>
    </div>
</div>
