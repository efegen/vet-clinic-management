@model PetDetailsViewModel
@{
    ViewData["Title"] = "Hayvan Sil";
}

<div class="page-header">
    <div>
        <a class="text-decoration-none text-muted small" asp-action="Details" asp-route-id="@Model.Id">
            <i class="bi bi-arrow-left me-1"></i>@Model.Name
        </a>
        <h1 class="mt-1 text-danger"><i class="bi bi-exclamation-triangle"></i> Hayvanı Sil</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <div class="card border-danger-subtle">
            <div class="card-header bg-danger-subtle text-danger-emphasis">
                <i class="bi bi-trash me-1"></i>Bu işlem geri alınamaz
            </div>
            <div class="card-body p-4">
                <p class="mb-3">Aşağıdaki hayvanı silmek üzeresiniz:</p>

                <dl class="row mb-3">
                    <dt class="col-sm-3 text-muted fw-normal">Ad</dt>
                    <dd class="col-sm-9 fw-semibold">@Model.Name <span class="badge @Model.SpeciesValue.BadgeClass() ms-1">@Model.Species</span></dd>

                    <dt class="col-sm-3 text-muted fw-normal">Sahibi</dt>
                    <dd class="col-sm-9">@Model.OwnerName</dd>

                    <dt class="col-sm-3 text-muted fw-normal">Randevu Sayısı</dt>
                    <dd class="col-sm-9">@Model.Appointments.Count</dd>
                </dl>

                @if (Model.Appointments.Any())
                {
                    <div class="alert alert-warning d-flex gap-2">
                        <i class="bi bi-exclamation-octagon-fill mt-1"></i>
                        <div>
                            Bu hayvan silinirse, ona ait <strong>@Model.Appointments.Count randevu</strong>
                            da kalıcı olarak silinecektir.
                        </div>
                    </div>
                }

                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex justify-content-end gap-2 mt-4">
                    @Html.AntiForgeryToken()
                    <a class="btn btn-light border" asp-action="Details" asp-route-id="@Model.Id">Vazgeç</a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Evet, Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
