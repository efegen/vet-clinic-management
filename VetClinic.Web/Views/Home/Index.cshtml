@model DashboardViewModel
@using System.Globalization
@{
    ViewData["Title"] = "Anasayfa";

    var tr = new CultureInfo("tr-TR");
    var inv = CultureInfo.InvariantCulture;
    var now = DateTime.Now;
    var today = now.Date;

    // Bu haftanın aralığı (KPI alt metni).
    int weekDiff = (7 + (today.DayOfWeek - DayOfWeek.Monday)) % 7;
    var weekStart = today.AddDays(-weekDiff);
    var weekEnd = weekStart.AddDays(6);

    // Bugün tamamlanan randevu sayısı (KPI + durum cümlesi için).
    var doneToday = Model.TodayAppointments.Count(a => a.StatusValue == AppointmentStatus.Tamamlandi);

    // "Sıradaki" — şu andan sonraki ilk randevu.
    var nextToday = Model.TodayAppointments
        .Where(a => a.AppointmentDate >= now)
        .OrderBy(a => a.AppointmentDate)
        .FirstOrDefault();
    var nextInMinutes = nextToday is null ? 0 : (int)Math.Round((nextToday.AppointmentDate - now).TotalMinutes);

    // Mini bar grafik için haftanın en yoğun günü (0'a bölünmeyi engeller).
    var maxWeek = Model.WeekDistribution.Count > 0 ? Model.WeekDistribution.Max(d => d.Count) : 0;

    // KPI ilerleme çubukları çoğunlukla görsel ritim içindir; yalnızca ilki (bugünün
    // tamamlanma oranı) gerçek veriye bağlıdır, diğerleri dekoratif sabit genişliktedir.
    var donePct = Model.TodayAppointmentCount > 0 ? doneToday * 100d / Model.TodayAppointmentCount : 0;

    string Pct(double v) => Math.Clamp(v, 0, 100).ToString("0.##", inv);

    string SpeciesTone(PetSpecies s) => s switch
    {
        PetSpecies.Kopek => "dog",
        PetSpecies.Kedi => "cat",
        PetSpecies.Tavsan => "rab",
        PetSpecies.Kus => "bird",
        _ => "oth"
    };

    string Initial(string name) => string.IsNullOrEmpty(name) ? "?" : name[..1].ToUpper(tr);
}

<div class="dash-root">

    @* --- 1. Hero satırı: durum paneli + hafta şeridi --- *@
    <section class="dash-hero fade-up" style="--delay:0ms">
        <div class="dash-status">
            <p class="dash-status-date">@now.ToString("d MMMM yyyy, dddd", tr)</p>
            <h1 class="dash-status-title">
                @if (Model.PendingAppointmentCount > 0)
                {
                    <text>Bugün @Model.TodayAppointmentCount randevu var, <b>@(Model.PendingAppointmentCount) tanesi</b> onayınızı bekliyor.</text>
                }
                else if (Model.TodayAppointmentCount > 0)
                {
                    <text>Bugün @Model.TodayAppointmentCount randevu var, tümü onaylı.</text>
                }
                else
                {
                    <text>Bugün için planlanmış randevu yok.</text>
                }
            </h1>
            <p class="dash-status-lead">
                @if (nextToday is not null)
                {
                    <text>Sıradaki — <b>@nextToday.AppointmentDate.ToString("HH:mm") · @nextToday.PetName</b> · @nextToday.ServiceName, @nextInMinutes dakika sonra.</text>
                }
                else
                {
                    <text>Bugün için kalan randevu yok.</text>
                }
            </p>
            <div class="dash-status-actions">
                <a class="dash-btn dash-btn--light" asp-controller="Appointments" asp-action="List" asp-route-status="@AppointmentStatus.Beklemede">
                    <i class="bi bi-check2-circle"></i>Onayları İncele
                </a>
                <a class="dash-btn dash-btn--ghost" asp-controller="Appointments" asp-action="Create">
                    <i class="bi bi-plus-lg"></i>Yeni Randevu
                </a>
            </div>
        </div>

        <div class="dash-week">
            <div class="dash-week-head">
                <span>Bu hafta</span>
                <b>@Model.ThisWeekAppointmentCount randevu</b>
            </div>
            <div class="dash-week-strip">
                @foreach (var d in Model.WeekDistribution)
                {
                    var h = maxWeek > 0 && d.Count > 0 ? d.Count * 100d / maxWeek : 0;
                    <div class="dash-day @(d.IsToday ? "is-today" : "") @(d.IsClosed ? "is-closed" : "")">
                        <div class="dash-day-bar"><span style="height:@Pct(h)%"></span></div>
                        <div class="dash-day-count">@(d.Count > 0 ? d.Count.ToString(inv) : "–")</div>
                        <div class="dash-day-label">@d.Label</div>
                    </div>
                }
            </div>
        </div>
    </section>

    @* --- 2. KPI tile satırı --- *@
    <section class="dash-kpis fade-up" style="--delay:80ms">
        <div class="dash-kpi dash-kpi--teal">
            <div class="dash-kpi-top">
                <span class="dash-kpi-icon"><i class="bi bi-calendar-day"></i></span>
                <span class="dash-kpi-label">Bugünkü Randevu</span>
            </div>
            <div class="dash-kpi-value">@Model.TodayAppointmentCount</div>
            <div class="dash-kpi-track"><span style="width:@Pct(donePct)%"></span></div>
            <div class="dash-kpi-sub">@doneToday tamamlandı</div>
        </div>

        <div class="dash-kpi dash-kpi--blue">
            <div class="dash-kpi-top">
                <span class="dash-kpi-icon"><i class="bi bi-calendar2-week"></i></span>
                <span class="dash-kpi-label">Bu Hafta</span>
            </div>
            <div class="dash-kpi-value">@Model.ThisWeekAppointmentCount</div>
            <div class="dash-kpi-track"><span style="width:72%"></span></div>
            <div class="dash-kpi-sub">@weekStart.ToString("dd MMM", tr) – @weekEnd.ToString("dd MMM", tr)</div>
        </div>

        <div class="dash-kpi dash-kpi--amber">
            <div class="dash-kpi-top">
                <span class="dash-kpi-icon"><i class="bi bi-hourglass-split"></i></span>
                <span class="dash-kpi-label">Onay Bekleyen</span>
            </div>
            <div class="dash-kpi-value">@Model.PendingAppointmentCount</div>
            <div class="dash-kpi-track"><span style="width:35%"></span></div>
            <div class="dash-kpi-sub">@(Model.PendingAppointmentCount > 0 ? "İşlem gerekiyor" : "Bekleyen yok")</div>
        </div>

        <div class="dash-kpi dash-kpi--rose">
            <div class="dash-kpi-top">
                <span class="dash-kpi-icon"><i class="bi bi-heart-pulse"></i></span>
                <span class="dash-kpi-label">Kayıtlı Hayvan</span>
            </div>
            <div class="dash-kpi-value">@Model.TotalPetCount</div>
            <div class="dash-kpi-track"><span style="width:88%"></span></div>
            <div class="dash-kpi-sub">@Model.TotalOwnerCount sahip</div>
        </div>
    </section>

    @* --- 3. İçerik satırı: bugünün randevuları + sağ ray --- *@
    <div class="dash-cols">
        <section class="dash-panel fade-up" style="--delay:140ms">
            <div class="dash-panel-head">
                <h2>Bugünün Randevuları</h2>
                <a asp-controller="Appointments" asp-action="Index">Tümü <i class="bi bi-arrow-right"></i></a>
            </div>
            @if (Model.TodayAppointments.Any())
            {
                <div class="dash-appts">
                    @foreach (var a in Model.TodayAppointments)
                    {
                        var aEnd = a.AppointmentDate.AddMinutes(a.DurationMinutes);
                        var isPast = aEnd <= now;
                        var isCurrent = !isPast && a.AppointmentDate <= now;
                        <a class="dash-appt @(isCurrent ? "is-current" : "") @(isPast ? "is-past" : "")"
                           asp-controller="Appointments" asp-action="Details" asp-route-id="@a.Id"
                           aria-label="@a.AppointmentDate.ToString("HH:mm") · @a.PetName · @a.ServiceName (@a.Status)">
                            <div class="dash-appt-time">@a.AppointmentDate.ToString("HH:mm")<i>@a.DurationMinutes dk</i></div>
                            <div class="dash-avatar dash-avatar--@SpeciesTone(a.Species)" aria-hidden="true">@Initial(a.PetName)</div>
                            <div class="dash-appt-main">
                                <div class="dash-appt-pet">@a.PetName <span>· @a.Species.ToText()</span></div>
                                <div class="dash-appt-svc">@a.ServiceName</div>
                                <div class="dash-appt-owner"><i class="bi bi-person"></i>@a.OwnerName</div>
                            </div>
                            <span class="dash-pill dash-pill--@a.StatusValue.BadgeFlavor()">@a.Status</span>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="empty-state py-4">
                    <i class="bi bi-cup-hot"></i>
                    <p class="mb-3">Bugün için planlanmış randevu yok.</p>
                    <a class="btn btn-outline-primary btn-sm" asp-controller="Appointments" asp-action="Create">
                        <i class="bi bi-plus-lg me-1"></i>Randevu Oluştur
                    </a>
                </div>
            }
        </section>

        <aside class="dash-rail">
            <section class="dash-panel fade-up" style="--delay:200ms">
                <div class="dash-panel-head">
                    <h2>En Çok Tercih Edilen</h2>
                    <span class="dash-tag">30 gün</span>
                </div>
                @if (Model.MostRequestedServices.Any())
                {
                    var maxSvc = Model.MostRequestedServices.Max(s => s.Count);
                    var rank = 0;
                    <div class="dash-svcs">
                        @foreach (var s in Model.MostRequestedServices)
                        {
                            var w = s.Count * 100d / Math.Max(1, maxSvc);
                            <div class="dash-svc">
                                <div class="dash-rank">@(rank + 1)</div>
                                <div class="dash-svc-body">
                                    <div class="dash-svc-head"><span>@s.ServiceName</span><b>@s.Count</b></div>
                                    <div class="dash-svc-bar"><span style="width:@Pct(w)%"></span></div>
                                </div>
                            </div>
                            rank++;
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state py-3">
                        <i class="bi bi-bar-chart"></i>
                        <p class="mb-0">Son 30 günde randevu bulunmuyor.</p>
                    </div>
                }
            </section>

            <section class="dash-panel fade-up" style="--delay:260ms">
                <div class="dash-panel-head"><h2>Yaklaşan</h2></div>
                @if (Model.UpcomingAppointments.Any())
                {
                    <ul class="dash-up">
                        @foreach (var u in Model.UpcomingAppointments.Take(3))
                        {
                            <li>
                                <a class="dash-up-row" asp-controller="Appointments" asp-action="Details" asp-route-id="@u.Id"
                                   aria-label="@u.AppointmentDate.ToString("d MMMM", tr) @u.AppointmentDate.ToString("HH:mm") · @u.PetName · @u.ServiceName (@u.Status)">
                                    <div class="dash-up-date">
                                        <b>@u.AppointmentDate.ToString("dd")</b>
                                        <span>@u.AppointmentDate.ToString("MMM", tr).ToUpper(tr)</span>
                                    </div>
                                    <div class="dash-up-main">
                                        <b>@u.PetName</b>
                                        <span>@u.AppointmentDate.ToString("HH:mm") · @u.ServiceName</span>
                                    </div>
                                    <span class="dash-pill dash-pill--@u.StatusValue.BadgeFlavor()">@u.Status</span>
                                </a>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="empty-state py-3">
                        <i class="bi bi-calendar2-x"></i>
                        <p class="mb-0">Yaklaşan randevu yok.</p>
                    </div>
                }
            </section>
        </aside>
    </div>
</div>
