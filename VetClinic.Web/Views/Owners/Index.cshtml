@model ListViewModel<OwnerListViewModel>
@{
    ViewData["Title"] = "Sahipler";
    var r = Model.Result;
    var hasSearch = !string.IsNullOrWhiteSpace(Model.Q);

    string SortIcon(string col) => Model.IsActiveSort(col)
        ? (Model.IsDescending ? "bi-sort-down" : "bi-sort-up")
        : "bi-arrow-down-up text-muted opacity-50";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-person-lines-fill text-primary"></i> Sahipler</h1>
        <span class="text-muted">Toplam @r.TotalCount kayıt@(hasSearch ? $" · \"{Model.Q}\" için filtrelendi" : "")</span>
    </div>
    <a class="btn btn-primary" asp-action="Create">
        <i class="bi bi-plus-lg me-1"></i>Yeni Sahip
    </a>
</div>

<div class="card">
    <div class="card-header d-flex flex-wrap gap-2 align-items-center justify-content-between">
        <form method="get" asp-action="Index" class="search-group">
            <span class="search-icon"><i class="bi bi-search"></i></span>
            <input type="search" name="q" value="@Model.Q" class="form-control"
                   placeholder="Ad, telefon veya e-posta ara…" autocomplete="off" aria-label="Ara" />
            <input type="hidden" name="sort" value="@Model.Sort" />
            <input type="hidden" name="dir" value="@Model.Dir" />
            @if (hasSearch)
            {
                <a class="search-clear" asp-action="Index" title="Aramayı temizle"><i class="bi bi-x-lg"></i></a>
            }
        </form>
        @if (hasSearch)
        {
            <span class="text-muted small">@r.TotalCount sonuç</span>
        }
    </div>

    @if (r.Items.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width:3rem">#</th>
                        <th>
                            <a class="th-sort" asp-action="Index" asp-route-q="@Model.Q"
                               asp-route-sort="name" asp-route-dir="@Model.NextDir("name")">
                                Ad Soyad <i class="bi @SortIcon("name") small"></i>
                            </a>
                        </th>
                        <th>
                            <a class="th-sort" asp-action="Index" asp-route-q="@Model.Q"
                               asp-route-sort="phone" asp-route-dir="@Model.NextDir("phone")">
                                Telefon <i class="bi @SortIcon("phone") small"></i>
                            </a>
                        </th>
                        <th>E-posta</th>
                        <th>Hayvanları</th>
                        <th>
                            <a class="th-sort" asp-action="Index" asp-route-q="@Model.Q"
                               asp-route-sort="date" asp-route-dir="@Model.NextDir("date")">
                                Kayıt <i class="bi @SortIcon("date") small"></i>
                            </a>
                        </th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var i = r.FirstItemIndex; }
                    @foreach (var owner in r.Items)
                    {
                        <tr>
                            <td class="text-muted">@i</td>
                            <td class="fw-semibold">@owner.FullName</td>
                            <td class="text-nowrap"><i class="bi bi-telephone text-muted me-1"></i>@owner.Phone.ToPhoneDisplay()</td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(owner.Email))
                                {
                                    <span class="text-muted">—</span>
                                }
                                else
                                {
                                    <a href="mailto:@owner.Email" class="text-decoration-none">@owner.Email</a>
                                }
                            </td>
                            <td>
                                @if (owner.PetNames.Count == 0)
                                {
                                    <span class="text-muted small">Hayvan yok</span>
                                }
                                else
                                {
                                    <span class="d-inline-flex flex-wrap gap-1 align-items-center">
                                        @foreach (var name in owner.PetNames.Take(3))
                                        {
                                            <span class="pet-chip"><i class="bi bi-heart-pulse me-1"></i>@name</span>
                                        }
                                        @if (owner.PetNames.Count > 3)
                                        {
                                            <span class="text-muted small">+@(owner.PetNames.Count - 3)</span>
                                        }
                                    </span>
                                }
                            </td>
                            <td class="text-muted text-nowrap">@owner.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@owner.Id" title="Detaylar">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@owner.Id" title="Düzenle">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@owner.Id" title="Sil">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white d-flex flex-wrap justify-content-between align-items-center gap-2 small text-muted">
            <span>@r.FirstItemIndex–@r.LastItemIndex / @r.TotalCount kayıt</span>
            <partial name="_Pager" model="PagerModel.From(r, Model.Q, Model.Sort, Model.Dir)" />
        </div>
    }
    else if (hasSearch)
    {
        <div class="empty-state">
            <i class="bi bi-search"></i>
            <p class="mb-3">"<strong>@Model.Q</strong>" ile eşleşen sahip bulunamadı.</p>
            <a class="btn btn-outline-secondary" asp-action="Index">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Aramayı Temizle
            </a>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-person-x"></i>
            <p class="mb-3">Henüz sahip kaydı yok.</p>
            <a class="btn btn-primary" asp-action="Create">
                <i class="bi bi-plus-lg me-1"></i>İlk Sahibi Ekle
            </a>
        </div>
    }
</div>
