@model ServiceCreateEditViewModel
@{
    ViewData["Title"] = "Hizmet Sil";
}

<div class="page-header">
    <div>
        <a class="text-decoration-none text-muted small" asp-action="Index">
            <i class="bi bi-arrow-left me-1"></i>Hizmetler
        </a>
        <h1 class="mt-1 text-danger"><i class="bi bi-exclamation-triangle"></i> Hizmeti Sil</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8 col-xl-7">
        <div class="card border-danger-subtle">
            <div class="card-header bg-danger-subtle text-danger-emphasis">
                <i class="bi bi-trash me-1"></i>Bu işlem geri alınamaz
            </div>
            <div class="card-body p-4">
                <p class="mb-3">
                    <strong>@Model.Name</strong> hizmetini kalıcı olarak silmek istediğinize emin misiniz?
                </p>
                <div class="alert alert-secondary small mb-0">
                    Yalnızca hiç randevusu olmayan hizmetler silinebilir. Randevusu olan bir hizmet için
                    silme yerine <em>pasifleştirme</em> kullanılır.
                </div>

                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex justify-content-end gap-2 mt-4">
                    @Html.AntiForgeryToken()
                    <a class="btn btn-light border" asp-action="Index">Vazgeç</a>
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Evet, Sil
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
